# ─── Clerk Authentication ───────────────────────────────────────────────────
# Get these from your Clerk dashboard → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Get this from Clerk dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Clerk (Client-side / Vite) ──────────────────────────────────────────────
# Must match CLERK_PUBLISHABLE_KEY; exposed to the browser via Vite
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ─── Neon Database ───────────────────────────────────────────────────────────
# Get from your Neon project dashboard → Connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ─── Stripe Payments ─────────────────────────────────────────────────────────
# Get from Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App Configuration ───────────────────────────────────────────────────────
# Used for Stripe checkout success/cancel redirect URLs
APP_BASE_URL=http://localhost:5000

# ─── AI Provider Keys ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
XAI_API_KEY=...
